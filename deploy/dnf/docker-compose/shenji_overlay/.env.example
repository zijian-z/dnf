# GitHub Container Registry 镜像
# 运行时真正需要的是下面两个镜像:
# 1. dnf-shenji-overlay
# 2. dnf-shenji-godofgm
# dnf:centos7-qf1031-* 只是构建 overlay 镜像时的基底，一般部署时不需要直接使用。
#
# 清风风格部署约定:
# - Script.pvf 直接放到 ./data/Script.pvf
# - data/godofgm/data.db 是 GodOfGM 运行所需文件
# - 发布镜像若内置 data.db 种子，首启会自动初始化到 ./data/godofgm/data.db
# - 后续所有网页 GM 产生的状态变更都保存在外部 ./data/godofgm/data.db
# - 镜像只会在目标文件缺失时初始化默认覆盖层，不会覆盖你已经放进 ./data 的文件
DNF_IMAGE=ghcr.io/<owner>/dnf-shenji-overlay:latest
GM_IMAGE=ghcr.io/<owner>/dnf-shenji-godofgm:latest

TZ=Asia/Shanghai

# 神迹覆盖层固定约束
SERVER_GROUP=3
SERVER_GROUP_DB=cain
DNF_DB_GAME_PASSWORD=uu5!^%jg
OPEN_CHANNEL=11

# 首次部署请至少修改以下两项
DNF_DB_ROOT_PASSWORD=88888888
GATE_AES_KEY=replace_with_64_hex_chars

# 强烈建议首次启动前修改 GodOfGM 超级管理员密码
GODOFGM_ADMIN_USERNAME=admin
GODOFGM_ADMIN_PASSWORD=replace_with_strong_password

# 可选
WEB_USER=root
WEB_PASS=123456
PUBLIC_IP=
AUTO_PUBLIC_IP=true
CLIENT_POOL_SIZE=10
